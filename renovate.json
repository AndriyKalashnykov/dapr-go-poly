{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "enabledManagers": [
    "gomod",
    "nuget",
    "dockerfile",
    "docker-compose",
    "github-actions",
    "mise",
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Makefile tool versions via inline renovate comments",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)( versioning=(?<versioning>[^\\s]+))?\\n[A-Z_]+\\s*:=\\s*(?<currentValue>v?\\d[\\w.+-]*)"
      ]
    },
    {
      "customType": "regex",
      "description": "Track the kindest/node image (tag + digest) pinned in the Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "KIND_NODE_IMAGE\\s*:=\\s*(?<depName>[^\\s:]+):(?<currentValue>[^\\s@]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Track the C4-PlantUML stdlib version pinned in diagram !include URLs",
      "managerFilePatterns": ["/docs/diagrams/.*\\.puml$/"],
      "matchStrings": [
        "raw\\.githubusercontent\\.com/plantuml-stdlib/C4-PlantUML/(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)/"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "plantuml-stdlib/C4-PlantUML"
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Bump Go version in go.mod to latest patch",
      "matchManagers": [
        "gomod"
      ],
      "matchDepNames": [
        "go"
      ],
      "rangeStrategy": "bump"
    },
    {
      "description": "Group the Go toolchain across go.mod + onboarding/Dockerfile + .mise.toml so a patch bump lands in one PR and check-go-alignment never deadlocks",
      "matchManagers": [
        "gomod",
        "dockerfile",
        "mise"
      ],
      "matchDepNames": [
        "go",
        "golang"
      ],
      "groupName": "Go toolchain"
    },
    {
      "description": "Group Dapr SDK dependencies (Go + .NET)",
      "matchPackageNames": [
        "/^github\\.com\\/dapr/",
        "/^Dapr/"
      ],
      "groupName": "Dapr SDK"
    },
    {
      "description": "Group Makefile-pinned tool versions into one PR",
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "Makefile tools"
    },
    {
      "description": "Group .NET Docker images, disable major updates",
      "matchPackageNames": [
        "dotnet-sdk",
        "mcr.microsoft.com/dotnet/aspnet",
        "mcr.microsoft.com/dotnet/sdk",
        "mcr.microsoft.com/dotnet/runtime",
        "mcr.microsoft.com/dotnet/runtime-deps"
      ],
      "groupName": "Dotnet Docker images",
      "extends": [
        ":disableMajorUpdates",
        ":pinDigestsDisabled"
      ]
    }
  ]
}
