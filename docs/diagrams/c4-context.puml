@startuml c4-context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.11.0/C4_Context.puml

title dapr-go-poly — C4 Context

skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam roundCorner 4
skinparam defaultFontName "Inter, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 13
skinparam ArrowColor #37474F
skinparam ArrowThickness 1.2
skinparam rectangleBorderThickness 1.3

UpdateElementStyle("person",           $fontColor="#FFFFFF", $bgColor="#0F766E", $borderColor="#134E4A")
UpdateElementStyle("system",           $fontColor="#FFFFFF", $bgColor="#2563EB", $borderColor="#1E3A8A")
UpdateElementStyle("external_system",  $fontColor="#1E293B", $bgColor="#E2E8F0", $borderColor="#94A3B8")
UpdateBoundaryStyle($bgColor="#F1F5F9", $borderColor="#94A3B8", $fontColor="#1E293B")

Person(dev, "Developer / Operator", "Issues HTTP requests against the services; monitors orders and onboarding workflows.")

System(dgp, "dapr-go-poly", "Polyglot microservices reference — Go and .NET services that share Postgres + RabbitMQ and exercise Dapr workflows.")

Rel(dev, dgp, "Creates products, places orders,\nruns onboarding workflows", "HTTP / JSON")

SHOW_LEGEND()
@enduml
