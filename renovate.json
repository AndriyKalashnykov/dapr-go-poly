{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":label(dependencies)",
    ":semanticCommitType(chore)",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":automergeMinor",
    ":automergePatch",
    ":automergePr",
    ":automergeRequireAllStatusChecks",
    ":prConcurrentLimitNone",
    "replacements:all",
    "workarounds:all",
    ":semanticPrefixFixDepsChoreOthers",
    "group:dotNetCore",
    "group:monorepos",
    "group:recommended"
  ],
  "major": {
    "automerge": true
  },
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "groupName": "ApplicationInsights",
      "matchPackageNames": [
        "/ApplicationInsights/"
      ]
    },
    {
      "groupName": "Dotnet",
      "matchPackageNames": [
        "dotnet-sdk",
        "mcr.microsoft.com/dotnet/aspnet",
        "mcr.microsoft.com/dotnet/sdk",
        "mcr.microsoft.com/dotnet/runtime",
        "mcr.microsoft.com/dotnet/runtime-deps"
      ],
      "extends": [
        ":disableMajorUpdates",
        ":pinDigestsDisabled"
      ]
    },
    {
      "groupName": "System.CommandLine",
      "matchPackageNames": [
        "/^System\\.CommandLine/"
      ]
    },
    {
      "groupName": "XUnit",
      "matchPackageNames": [
        "/^xunit/"
      ]
    },
    {
      "description": "Automerge all Go dependencies when checks pass",
      "matchManagers": ["gomod"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "ignoreTests": false
    },
    {
      "description": "Automerge all .NET dependencies when checks pass",
      "matchManagers": ["nuget"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "ignoreTests": false
    },
    {
      "matchManagers": ["gomod"],
      "matchDepTypes": ["golang"],
      "enabled": false
    }
  ],
  "platformAutomerge": true,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "dependencyDashboard": true,
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "rebaseWhen": "conflicted"
}
