# Committed source-of-truth for operator-tunable values. Copy to `.env`
# (gitignored) and edit to override. `docker compose` auto-loads `.env`;
# the e2e script sources this file first, then `.env`. Every value below is
# mirrored as a `${VAR:-default}` fallback at its use site, so the stack works
# with no `.env` present.

# === Host-side ports (override to run multiple stacks without collisions) ===
PRODUCT_HOST_PORT=1000
ORDER_HOST_PORT=1001
ONBOARDING_HOST_PORT=1002
POSTGRES_HOST_PORT=5432
RABBITMQ_HOST_PORT=5672
RABBITMQ_MGMT_HOST_PORT=15672
DAPR_PLACEMENT_HOST_PORT=50006
DAPR_SCHEDULER_HOST_PORT=50007

# === Application ===
# Container-internal HTTP port. Consumed by the Go services (APP_PORT), the
# .NET services (ASPNETCORE_URLS), and the daprd sidecars (-app-port).
APP_INTERNAL_PORT=8080

# === Postgres ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=test
POSTGRES_DB=product            # database the postgres container initializes
PRODUCT_DATABASE=product       # schema database for product-service
ORDER_DATABASE=order           # schema database for order-service

# === RabbitMQ ===
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# === Inter-service ===
PRODUCT_SERVICE_BASE_URL=http://product-service:8080

# === Dapr control plane + sidecar ports ===
DAPR_PLACEMENT_PORT=50006     # placement service port (container + addresses)
DAPR_SCHEDULER_PORT=50007     # scheduler service port (container + addresses)
DAPR_GRPC_PORT=50001          # daprd gRPC port (onboarding sidecar)
DAPR_HTTP_PORT=3500           # daprd HTTP port (used by `make dapr-run`)

# === e2e harness (host-side curl targets + readiness tuning) ===
PRODUCT_BASE=http://localhost:1000
ORDER_BASE=http://localhost:1001
ONBOARDING_BASE=http://localhost:1002
RABBIT_API=http://localhost:15672
RABBIT_USER=guest
RABBIT_PASS=guest
READINESS_TIMEOUT=60
